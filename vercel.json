{
  "version": 2,
  "public": false,
  "builds": [{ "src": "app.py", "use": "@vercel/python" }],
  "routes": [
    { "src": "/stream", "dest": "app.py" },
    { "src": "/docs", "dest": "app.py" },
    { "src": "/openapi.json", "dest": "app.py" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
