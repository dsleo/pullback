# =============================================================================
# API Keys
# =============================================================================

# Required for LLM query planning and OpenAI embedding reranker
# Without this, set MATHGENT_LIBRARIAN_MODEL=test and MATHGENT_RERANKER=token_overlap
OPENAI_API_KEY=

# Required for fetching arXiv LaTeX sources (via E2B Code Interpreter sandbox)
# Not needed if you provide a local TeX cache (MATHGENT_LOCAL_TEX_DIR)
E2B_API_KEY=

# Optional: higher rate limits on OpenAlex discovery
OPENALEX_API_KEY=
# Optional: polite-pool access for OpenAlex (your email address)
OPENALEX_MAILTO=

# Optional: LLM-based discovery via OpenRouter (openrouter_search provider)
OPENROUTER_API_KEY=

# =============================================================================
# Orchestration
# =============================================================================

# Librarian/query-planner model
# Examples: openai:gpt-4o-mini  openrouter:anthropic/claude-3-haiku
# Set to "test" for deterministic mode (no LLM calls)
MATHGENT_LIBRARIAN_MODEL=openai:gpt-4o-mini
MATHGENT_AGENTIC=1
MATHGENT_MAX_QUERY_ATTEMPTS=2
MATHGENT_MAX_REPLAN_ROUNDS=2
MATHGENT_QUERY_PLANNER_MODEL=
MATHGENT_DELEGATE_CONCURRENCY=4
MATHGENT_TOP_K_HEADERS=10

# =============================================================================
# Discovery
# =============================================================================

# Active providers (run in parallel). Available: openalex, zbmath_open, arxiv_api,
# semantic_scholar, openrouter_search, openai_search
MATHGENT_DISCOVERY_PROVIDERS=openalex,zbmath_open,arxiv_api,semantic_scholar

# Model for openrouter_search / openai_search providers (if enabled above)
MATHGENT_LLM_SEARCH_MODEL=openai:gpt-4o-mini

# Shared timeout in seconds for discovery + planner + metadata
MATHGENT_TIMEOUT_SECONDS=60.0

# =============================================================================
# Sandbox (LaTeX source fetching)
# =============================================================================

# Local directory of cached .tex files (named {arxiv_id}.tex)
# See data/tex_cache/README.md. If unset, E2B_API_KEY is used instead.
MATHGENT_LOCAL_TEX_DIR=

# =============================================================================
# Reranker
# =============================================================================

# Strategy: auto, token_overlap, openai_embedding, hybrid_token_openai, bge, colbert
MATHGENT_RERANKER=auto
MATHGENT_COLBERT_ENDPOINT=http://127.0.0.1:8001/rerank
MATHGENT_BGE_MODEL=BAAI/bge-reranker-v2-m3

# =============================================================================
# Observability
# =============================================================================

MATHGENT_LOG_LEVEL=INFO
MATHGENT_LOG_JSON=0
MATHGENT_LOG_FILE_ENABLED=1
MATHGENT_LOG_FILE=logs/mathgent.log
MATHGENT_LOG_FILE_ROTATION=20 MB
MATHGENT_LOG_FILE_RETENTION=14 days
MATHGENT_ENABLE_LOGFIRE=1
MATHGENT_LOGFIRE_SEND=0
MATHGENT_PYDANTICAI_INSTRUMENT=1
